{
    "name": "amzs-cms/page-bundle",
    "description": "Module management user for the CMS system",
    "type": "symfony-bundle",
    "require": {
        "php": "7.4.33",
        "symfony/framework-bundle": "^5.4 || ^6.4 || ^7.0",
        "symfony/security-bundle": "^5.4 || ^6.4 || ^7.0",
        "doctrine/orm": "^2.10 || ^3.0",
        "doctrine/doctrine-bundle": "^2.7",
        "symfony/validator": "^5.4 || ^6.4 || ^7.0",
        "symfony/rate-limiter": "^5.4 || ^6.4 || ^7.0",
        "twig/extra-bundle": "^3.11",
        "twig/twig": "^3.11",
        "ext-json": "*",
        "symfony/serializer-pack": "^1.3",
        "amzs-cms/user-bundle": "dev-main",
        "amzs-cms/core-bundle": "dev-main",
        "amzs-cms/article-bundle": "dev-main",
        "amzs-cms/topic-bundle": "dev-main"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../core-bundle"
        },
        {
            "type": "path",
            "url": "../user-bundle"
        },
        {
            "type": "path",
            "url": "../article-bundle"
        },
        {
            "type": "path",
            "url": "../topic-bundle"
        }

    ],
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "AmzsCMS\\PageBundle\\": "src/"
        }
    },
    "authors": [
        {
            "name": "ductapcodephp",
            "email": "ductapcode@gmail.com"
        }
    ],
    "minimum-stability": "dev"
}
